[Unit]
Description=Internet Blocker - Kids screen time enforcer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/src/internet-blocker-for-kids
ExecStart=%h/.local/bin/uv run internet_blocker.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target

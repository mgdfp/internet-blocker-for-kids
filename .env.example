UDM_IP=192.168.1.1
UNIFI_API_KEY=your_api_key_here

# Only track devices on this VLAN (leave unset or 0 to track all VLANs)
VLAN_ID=4

# Poll interval in seconds (default 300 = 5 min; use a lower value for testing)
POLL_INTERVAL_SECONDS=300

# UniFi usergroup _id for the throttled WiFi Speed Limit profile.
# 1. Create a speed limit profile in UniFi UI (e.g. 1/1 Mbps)
# 2. Apply it to any client, then run: uv run internet_blocker.py --dump <mac>
# 3. Copy the "usergroup_id" value from the output.
THROTTLE_PROFILE_ID=your_usergroup_id_here

# Name of the VLAN4 WiFi network in UniFi — used to update the MAC allowlist via /add
WLAN_NAME=your_wifi_network_name

# Twilio credentials for SMS notifications to kids (optional — omit to disable SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Telegram bot for Morgan's admin commands (optional — omit to disable)
# Get TELEGRAM_BOT_TOKEN from @BotFather, TELEGRAM_CHAT_ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# One line per person. Format: CLIENTx=name,mac,limit[,phone]
# Limit: number of minutes (e.g. 60min) or "unlimited"
# Phone: optional E.164 format (e.g. +4712345678) — omit for no SMS
# Unlimited clients are still tracked in logs but never throttled.
CLIENT1=fabian,aa:bb:cc:dd:ee:01,60min,+4712345678
CLIENT2=emilian,aa:bb:cc:dd:ee:02,60min,+4787654321
CLIENT3=julian,aa:bb:cc:dd:ee:03,60min,+4711223344
CLIENT4=morgan,aa:bb:cc:dd:ee:04,unlimited
CLIENT5=dag,aa:bb:cc:dd:ee:05,unlimited

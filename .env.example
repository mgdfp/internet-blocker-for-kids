UDM_IP=192.168.1.1
UNIFI_API_KEY=your_api_key_here

# One line per person. Format: CLIENTx=name,mac,limit
# Limit can be a number of minutes (e.g. 60min) or "unlimited"
# Unlimited clients are still tracked in logs but never blocked.
CLIENT1=fabian,aa:bb:cc:dd:ee:01,60min
CLIENT2=emilian,aa:bb:cc:dd:ee:02,60min
CLIENT3=julian,aa:bb:cc:dd:ee:03,60min
CLIENT4=morgan,aa:bb:cc:dd:ee:04,unlimited
CLIENT5=dag,aa:bb:cc:dd:ee:05,unlimited
